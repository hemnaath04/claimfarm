# Qwen Cloud (DashScope-compatible)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBED_MODEL=text-embedding-v3

# Alibaba Cloud
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=ap-southeast-1

# Alibaba OSS (file storage)
OSS_BUCKET=claimfarm-files
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# Vector store: choose "chroma" (local) or "dashvector" (Alibaba prod)
VECTOR_STORE=chroma
CHROMA_PATH=./.chroma

# Alibaba DashVector (only used when VECTOR_STORE=dashvector)
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_CLUSTER=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Bird (MessageBird) WhatsApp — alternative to Twilio
BIRD_API_KEY=
BIRD_WORKSPACE_ID=
BIRD_CHANNEL_ID=
BIRD_SANDBOX_FROM=
BIRD_BASE_URL=https://api.bird.com

# Telegram Bot — the channel that actually works on a free tier
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org

# Identity verification (KYC + liveness). Defaults to a deterministic mock
# so the rest of the system can run without a real provider.
# Values: mock | stripe_identity | persona | veriff | onfido
IDENTITY_PROVIDER=mock
PERSONA_API_KEY=
VERIFF_API_KEY=
ONFIDO_API_KEY=

# Payments — disabled by default. Pick a merchant-of-record (no business /
# no SSN required) to enable real charges:
#   paddle, lemonsqueezy, razorpay, or 'none' to disable.
PAYMENTS_PROVIDER=none

# Paddle (https://paddle.com — recommended for solo founders)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_GROWTH_PRICE_ID=

# LemonSqueezy (https://lemonsqueezy.com — same MoR model as Paddle)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_GROWTH_VARIANT_ID=

# Razorpay (https://razorpay.com — India / INR market)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email / SMS — logged-only when unset
RESEND_API_KEY=
SENDGRID_API_KEY=
TWILIO_SMS_FROM=

# Rate limit (per IP per minute, on /api/* and /auth/*)
RATE_LIMIT_PER_MINUTE=60

# Open-Meteo (no key needed)
OPEN_METEO_BASE=https://archive-api.open-meteo.com/v1/archive

# App
DATABASE_URL=sqlite:///./claimfarm.sqlite
PUBLIC_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
